# ════════════════════════════════════════════
# DISCORD BOT CONFIG — Copy this to .env and fill in your values
# ════════════════════════════════════════════

# STEP 1: Get this from Discord Developer Portal
DISCORD_TOKEN=your_bot_token_here_12345

# STEP 2: Get this from Discord Developer Portal (Application ID)
CLIENT_ID=your_client_id_here_67890

# STEP 3: Get this by right-clicking your Discord server
GUILD_ID=your_server_id_here_11111

# ════════════════════════════════════════════
# CHANNELS — Get these by right-clicking in Discord
# ════════════════════════════════════════════
CHANNEL_ANNOUNCEMENTS=123456789
CHANNEL_WELCOME=123456789
CHANNEL_LOGS=123456789
CHANNEL_GENERAL=123456789

# ════════════════════════════════════════════
# STAFF ROLES — Get these by right-clicking roles
# ════════════════════════════════════════════
ROLE_OWNER=123456789
ROLE_HEAD_ADMIN=123456789
ROLE_ADMIN=123456789
ROLE_MOD=123456789

# ════════════════════════════════════════════
# LEVEL ROLES — Get these by right-clicking roles
# ════════════════════════════════════════════
ROLE_BABY_BADDIE=123456789
ROLE_PARTY_GIRL=123456789
ROLE_SHES_GIVING=123456789
ROLE_THAT_GIRL=123456789
ROLE_STAYED_BADDIE=123456789
ROLE_CHOSEN_BADDIE=123456789

# ════════════════════════════════════════════
# SETTINGS
# ════════════════════════════════════════════
BOT_STATUS=Chatting with the baddies
ENABLE_XP_GAIN=true
ENABLE_COIN_GAIN=true
ENABLE_SHOP=true
